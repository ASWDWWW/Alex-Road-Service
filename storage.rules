rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuth() {
      return request.auth != null;
    }
    function role() {
      return request.auth.token.role;
    }
    function isActiveStaff() {
      return isAuth()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.active == true
        && !(firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.status
          in ['Archived', 'Terminated']);
    }
    function isAdminOrDev() {
      return isActiveStaff() && role() in ['admin', 'developer'];
    }
    function isOffice() {
      return isActiveStaff() && role() in ['admin', 'office', 'developer'];
    }
    function isStaff() {
      return isActiveStaff() && role() in ['admin', 'office', 'technician', 'developer'];
    }
    function isConversationParticipant(conversationId) {
      return isActiveStaff()
        && request.auth.uid in firestore.get(
          /databases/(default)/documents/conversations/$(conversationId)
        ).data.participantIds;
    }
    function canAccessWorkOrder(workOrderId) {
      return isOffice()
        || (isActiveStaff()
          && role() == 'technician'
          && request.auth.uid in firestore.get(
            /databases/(default)/documents/workOrders/$(workOrderId)
          ).data.techIds);
    }
    function isImageOrVideo() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType.matches('video/.*');
    }
    function isImageVideoOrPdf() {
      return isImageOrVideo() || request.resource.contentType == 'application/pdf';
    }
    function underImageLimit() {
      return request.resource.size < 12 * 1024 * 1024;
    }
    function underVideoLimit() {
      return request.resource.size < 60 * 1024 * 1024;
    }
    function underPdfLimit() {
      return request.resource.size < 12 * 1024 * 1024;
    }
    function validSize() {
      return (request.resource.contentType.matches('image/.*') && underImageLimit())
        || (request.resource.contentType.matches('video/.*') && underVideoLimit())
        || (request.resource.contentType == 'application/pdf' && underPdfLimit());
    }

    match /media/workOrders/{woId}/{fileName} {
      allow read: if canAccessWorkOrder(woId);
      allow create: if canAccessWorkOrder(woId) && isImageOrVideo() && validSize();
      allow update: if false;
      allow delete: if canAccessWorkOrder(woId);
    }

    match /media/trucks/{truckId}/{fileName} {
      allow read: if isStaff();
      allow create: if isOffice() && isImageOrVideo() && validSize();
      allow update: if false;
      allow delete: if isOffice();
    }

    match /media/estimates/{estId}/{fileName} {
      allow read: if isStaff();
      allow create: if isOffice() && isImageOrVideo() && validSize();
      allow update: if isOffice() && isImageOrVideo() && validSize();
      allow delete: if isOffice();
    }

    match /media/leads/{leadId}/{fileName} {
      allow read: if isOffice();
      allow create: if isOffice() && isImageOrVideo() && validSize();
      allow update: if isOffice() && isImageOrVideo() && validSize();
      allow delete: if isOffice();
    }

    match /media/public_leads/{uploadId}/{fileName} {
      allow read: if isOffice();
      allow create: if false;
      allow update, delete: if isOffice();
    }

    match /media/invoices/{invId}/{fileName} {
      allow read: if isOffice();
      allow create: if isOffice() && isImageVideoOrPdf() && validSize();
      allow update: if isOffice() && isImageVideoOrPdf() && validSize();
      allow delete: if isOffice();
    }

    match /media/inventory/{partId}/{fileName} {
      allow read: if isStaff();
      allow create: if isOffice() && request.resource.contentType.matches('image/.*') && underImageLimit();
      allow update: if isOffice() && request.resource.contentType.matches('image/.*') && underImageLimit();
      allow delete: if isOffice();
    }

    match /media/customers/{custId}/{fileName} {
      allow read: if isOffice();
      allow create: if isOffice() && request.resource.contentType.matches('image/.*') && underImageLimit();
      allow update: if isOffice() && request.resource.contentType.matches('image/.*') && underImageLimit();
      allow delete: if isOffice();
    }

    match /media/settings/logo/{fileName} {
      allow read: if isActiveStaff();
      allow create, update: if isAdminOrDev()
        && request.resource.contentType.matches('image/.*')
        && underImageLimit();
      allow delete: if isAdminOrDev();
    }

    match /media/users/{userId}/avatar/{fileName} {
      allow read: if isActiveStaff();
      allow create, update: if isActiveStaff()
        && request.auth.uid == userId
        && request.resource.contentType.matches('image/.*')
        && underImageLimit();
      allow delete: if isActiveStaff() && request.auth.uid == userId;
    }

    match /media/users/{userId}/docs/{fileName} {
      allow read: if isOffice() || (isActiveStaff() && request.auth.uid == userId);
      allow create: if (isAdminOrDev() || (isActiveStaff() && request.auth.uid == userId))
        && isImageVideoOrPdf() && validSize();
      allow update: if (isAdminOrDev() || (isActiveStaff() && request.auth.uid == userId))
        && isImageVideoOrPdf() && validSize();
      allow delete: if isAdminOrDev();
    }

    match /media/messages/{conversationId}/{fileName} {
      allow read: if isConversationParticipant(conversationId);
      allow create: if isConversationParticipant(conversationId)
        && isImageVideoOrPdf() && validSize();
      allow update: if false;
      allow delete: if isConversationParticipant(conversationId);
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function isDeveloper() {
      return isAuth() && role() == 'developer';
    }

    function isAdmin() {
      return isAuth() && role() == 'admin';
    }

    function isAdminOrDev() {
      return isDeveloper() || isAdmin();
    }

    function isOffice() {
      return isAuth() && role() in ['admin', 'office', 'developer'];
    }

    function isTech() {
      return isAuth() && role() in ['admin', 'office', 'technician', 'developer'];
    }

    match /users/{userId} {
      // Office needs to list technicians for WO assignment and view the employee directory
      allow read: if isAuth() && (request.auth.uid == userId || isOffice() || isAdminOrDev());
      allow create: if isAdminOrDev();
      allow update: if isAdminOrDev()
        || (isAuth()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                'phone', 'address', 'emergencyContact', 'photoURL',
                'avatarPath', 'avatarMedia', 'certifications', 'media',
                'messagingPublicKey', 'messagingKeyUpdatedAt', 'updatedAt',
              ]));
      allow delete: if isDeveloper();
    }

    match /customers/{docId} {
      allow read: if isTech();
      allow create, update: if isOffice();
      allow delete: if isDeveloper();
    }

    match /trucks/{docId} {
      allow read: if isTech();
      allow create, update: if isOffice();
      allow delete: if isDeveloper();
    }

    match /workOrders/{docId} {
      allow read: if isTech();
      allow create: if isOffice();
      allow update: if isOffice() || (isAuth() && role() == 'technician');
      allow delete: if isDeveloper();
    }

    match /estimates/{docId} {
      allow read: if isTech();
      allow create, update: if isOffice();
      allow delete: if isDeveloper();
    }

    match /invoices/{docId} {
      allow read: if isOffice();
      allow create, update: if isOffice();
      allow delete: if isDeveloper();
    }

    match /payments/{docId} {
      allow read: if isOffice();
      allow create, update, delete: if false;
    }

    match /stripe_events/{docId} {
      allow read, write: if false;
    }

    match /inventory/{docId} {
      allow read: if isTech();
      allow create, update: if isOffice();
      allow delete: if isDeveloper();
    }

    match /inventoryTransactions/{docId} {
      allow read: if isOffice();
      allow create, update: if isOffice();
      allow delete: if isDeveloper();
    }

    match /notifications/{docId} {
      allow read, update: if isAuth() && (resource.data.userId == request.auth.uid || isAdminOrDev());
      allow create: if isOffice();
      allow delete: if isDeveloper();
    }

    match /settings/{docId} {
      allow read: if isAuth();
      allow write: if isAdminOrDev();
    }

    match /audit_log/{docId} {
      allow read: if isAdminOrDev();
      allow write: if false;
    }

    match /counters/{docId} {
      allow read, write: if false;
    }

    match /contact_submissions/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.email is string;
      allow read: if isOffice();
      allow update: if isOffice();
      allow delete: if isDeveloper();
    }

    // Legacy camelCase collection — read-only; app uses contact_submissions
    match /contactSubmissions/{docId} {
      allow read: if isOffice();
      allow write: if false;
    }

    // Public staff directory for messaging (no HR-sensitive fields) — created by Cloud Functions
    match /messagingRoster/{uid} {
      allow read: if isTech();
      allow create: if false;
      allow update: if isAuth()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['messagingPublicKey', 'messagingKeyUpdatedAt', 'updatedAt', 'photoURL', 'name']);
      allow delete: if false;
    }

    // Internal E2EE staff messaging — ciphertext only; plaintext never stored server-side
    match /conversations/{cid} {
      function isParticipant() {
        return isAuth() && request.auth.uid in resource.data.participantIds;
      }
      function creatingAsParticipant() {
        return isAuth()
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.participantIds is list
          && request.resource.data.participantIds.size() >= 2
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.keys().hasAll(['type', 'participantIds', 'createdBy', 'createdAt']);
      }

      // Allow get on missing docs so clients can check deterministic DM ids before create
      allow get: if isAuth() && (
        !exists(/databases/$(database)/documents/conversations/$(cid))
        || isParticipant()
      );
      // List queries must be scoped with participantIds array-contains (enforced by client)
      allow list: if isParticipant();
      allow create: if creatingAsParticipant();
      allow update: if isParticipant();
      allow delete: if isAdminOrDev();

      match /messages/{mid} {
        function convoParticipants() {
          return get(/databases/$(database)/documents/conversations/$(cid)).data.participantIds;
        }
        allow read: if isAuth() && request.auth.uid in convoParticipants();
        allow create: if isAuth()
          && request.auth.uid in convoParticipants()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.keys().hasAll(['senderId', 'ciphertext', 'iv', 'createdAt']);
        allow update: if isAuth()
          && request.auth.uid == resource.data.senderId
          && request.resource.data.senderId == resource.data.senderId;
        allow delete: if isAdminOrDev();
      }
    }

    // Staff calendar blocks (meetings, lunch, time off, custom) — WOs overlay client-side
    match /scheduleBlocks/{blockId} {
      function canManageSchedule() {
        return isOffice() || isAdminOrDev();
      }
      function creatingSelfOnly() {
        return isAuth()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.employeeIds is list
          && request.resource.data.employeeIds.size() == 1
          && request.auth.uid in request.resource.data.employeeIds
          && request.resource.data.get('targetAll', false) != true
          && request.resource.data.keys().hasAll([
            'title', 'type', 'startAt', 'endAt', 'employeeIds', 'createdBy', 'createdAt'
          ]);
      }
      function creatingManaged() {
        return canManageSchedule()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.employeeIds is list
          && request.resource.data.employeeIds.size() >= 1
          && request.resource.data.keys().hasAll([
            'title', 'type', 'startAt', 'endAt', 'employeeIds', 'createdBy', 'createdAt'
          ]);
      }

      // Managers: all blocks. Staff: assigned blocks + company-wide (targetAll) pushes.
      allow read: if canManageSchedule()
        || (isAuth() && request.auth.uid in resource.data.employeeIds)
        || (isAuth() && resource.data.get('targetAll', false) == true && isTech());
      allow create: if creatingManaged() || creatingSelfOnly();
      allow update: if canManageSchedule()
        || (isAuth()
          && resource.data.createdBy == request.auth.uid
          && request.auth.uid in resource.data.employeeIds
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.get('targetAll', false) != true
          && request.resource.data.employeeIds.size() == 1
          && request.auth.uid in request.resource.data.employeeIds);
      allow delete: if canManageSchedule()
        || (isAuth()
          && resource.data.createdBy == request.auth.uid
          && request.auth.uid in resource.data.employeeIds);
    }
  }
}

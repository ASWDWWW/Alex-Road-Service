rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function isActiveStaff() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true
        && !(get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status
          in ['Archived', 'Terminated']);
    }

    function isDeveloper() {
      return isActiveStaff() && role() == 'developer';
    }

    function isAdmin() {
      return isActiveStaff() && role() == 'admin';
    }

    function isAdminOrDev() {
      return isDeveloper() || isAdmin();
    }

    function isOffice() {
      return isActiveStaff() && role() in ['admin', 'office', 'developer'];
    }

    function isTech() {
      return isActiveStaff() && role() in ['admin', 'office', 'technician', 'developer'];
    }

    match /users/{userId} {
      // Own profile must be readable for login/session bootstrap, even when inactive.
      allow get: if isAuth() && request.auth.uid == userId;
      allow list: if isActiveStaff() && isAdminOrDev();
      allow create: if isAdminOrDev();
      allow update: if isAdminOrDev()
        || (isActiveStaff()
          && request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.active == resource.data.active
          && request.resource.data.status == resource.data.status
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly([
                'phone', 'address', 'emergencyContact', 'photoURL',
                'avatarPath', 'avatarMedia', 'certifications', 'media',
                'messagingPublicKey', 'messagingKeyUpdatedAt', 'updatedAt',
              ]));
      allow delete: if isDeveloper();
    }

    match /customers/{docId} {
      allow read: if isTech();
      allow write: if false;
    }

    match /trucks/{docId} {
      allow read: if isTech();
      allow write: if false;
    }

    match /workOrders/{docId} {
      function assignedTechnician(data) {
        return isActiveStaff()
          && role() == 'technician'
          && data.techIds is list
          && request.auth.uid in data.techIds;
      }
      allow read: if isOffice() || assignedTechnician(resource.data);
      allow write: if false;
    }

    match /estimates/{docId} {
      allow read: if isTech();
      allow write: if false;
    }

    match /invoices/{docId} {
      allow read: if isOffice();
      allow write: if false;
    }

    match /payments/{docId} {
      allow read: if isOffice();
      allow create, update, delete: if false;
    }

    match /stripe_events/{docId} {
      allow read, write: if false;
    }

    match /inventory/{docId} {
      allow read: if isTech();
      allow write: if false;
    }

    match /inventoryTransactions/{docId} {
      allow read: if isOffice();
      allow write: if false;
    }

    match /notifications/{docId} {
      allow read, update: if isActiveStaff()
        && (resource.data.userId == request.auth.uid || isAdminOrDev());
      allow create: if isOffice();
      allow delete: if isDeveloper();
    }

    match /settings/{docId} {
      allow read: if isActiveStaff();
      allow write: if false;
    }

    match /audit_log/{docId} {
      allow read: if isAdminOrDev();
      allow write: if false;
    }

    match /counters/{docId} {
      allow read, write: if false;
    }

    match /contact_submissions/{docId} {
      allow create: if false;
      allow read: if isOffice();
      allow update, delete: if false;
    }

    // Legacy camelCase collection — read-only; app uses contact_submissions
    match /contactSubmissions/{docId} {
      allow read: if isOffice();
      allow write: if false;
    }

    // Public staff directory for messaging (no HR-sensitive fields) — created by Cloud Functions
    match /messagingRoster/{uid} {
      allow read: if isTech();
      allow create: if false;
      allow update: if isActiveStaff()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['messagingPublicKey', 'messagingKeyUpdatedAt', 'updatedAt', 'photoURL', 'name']);
      allow delete: if false;
    }

    // Internal E2EE staff messaging — ciphertext only; plaintext never stored server-side
    match /conversations/{cid} {
      function isParticipant() {
        return isActiveStaff() && request.auth.uid in resource.data.participantIds;
      }
      function creatingAsParticipant() {
        return isActiveStaff()
          && request.auth.uid in request.resource.data.participantIds
          && request.resource.data.participantIds is list
          && request.resource.data.participantIds.size() >= 2
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.keys().hasAll(['type', 'participantIds', 'createdBy', 'createdAt']);
      }

      // Allow get on missing docs so clients can check deterministic DM ids before create
      allow get: if isActiveStaff() && (
        !exists(/databases/$(database)/documents/conversations/$(cid))
        || isParticipant()
      );
      // List queries must be scoped with participantIds array-contains (enforced by client)
      allow list: if isParticipant();
      allow create: if creatingAsParticipant();
      allow update: if isParticipant()
        && request.resource.data.participantIds == resource.data.participantIds
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'title', 'wrappedKeys', 'participantPublicKeys', 'e2ee',
          'lastMessageAt', 'lastMessageBy', 'lastReadAt', 'updatedAt'
        ]);
      allow delete: if isAdminOrDev();

      match /messages/{mid} {
        function convoParticipants() {
          return get(/databases/$(database)/documents/conversations/$(cid)).data.participantIds;
        }
        allow read: if isActiveStaff() && request.auth.uid in convoParticipants();
        allow create: if isActiveStaff()
          && request.auth.uid in convoParticipants()
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.keys().hasAll(['senderId', 'ciphertext', 'iv', 'createdAt']);
        allow update: if false;
        allow delete: if isAdminOrDev();
      }
    }

    // Staff calendar blocks (meetings, lunch, time off, custom) — WOs overlay client-side
    match /scheduleBlocks/{blockId} {
      function canManageSchedule() {
        return isOffice() || isAdminOrDev();
      }
      function validScheduleBlock(data) {
        return data.keys().hasAll([
            'title', 'type', 'color', 'startAt', 'endAt', 'allDay', 'notes',
            'employeeIds', 'employeeNames', 'targetAll', 'createdBy',
            'createdByName', 'createdAt', 'updatedAt'
          ])
          && data.keys().hasOnly([
            'title', 'type', 'color', 'startAt', 'endAt', 'allDay', 'notes',
            'employeeIds', 'employeeNames', 'targetAll', 'createdBy',
            'createdByName', 'createdAt', 'updatedAt'
          ])
          && data.title is string
          && data.title.size() >= 1
          && data.title.size() <= 80
          && data.type in ['meeting', 'lunch', 'time_off', 'training', 'shop', 'other']
          && data.color is string
          && data.color.matches('^#[0-9a-fA-F]{6}$')
          && data.startAt is string
          && data.startAt.size() <= 40
          && data.endAt is string
          && data.endAt.size() <= 40
          && data.startAt < data.endAt
          && data.allDay is bool
          && data.notes is string
          && data.notes.size() <= 1000
          && data.employeeIds is list
          && data.employeeIds.size() >= 1
          && data.employeeIds.size() <= 100
          && data.employeeNames is map
          && data.employeeNames.size() <= 100
          && data.targetAll is bool
          && data.createdBy is string
          && data.createdBy.size() >= 1
          && data.createdBy.size() <= 128
          && data.createdByName is string
          && data.createdByName.size() <= 100
          && data.createdAt is string
          && data.createdAt.size() <= 40
          && data.updatedAt is string
          && data.updatedAt.size() <= 40;
      }
      function creatingSelfOnly() {
        return isActiveStaff()
          && validScheduleBlock(request.resource.data)
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.employeeIds.size() == 1
          && request.auth.uid in request.resource.data.employeeIds
          && request.resource.data.targetAll == false;
      }
      function creatingManaged() {
        return canManageSchedule()
          && validScheduleBlock(request.resource.data)
          && request.resource.data.createdBy == request.auth.uid;
      }

      // Managers: all blocks. Staff: assigned blocks + company-wide (targetAll) pushes.
      allow read: if canManageSchedule()
        || (isActiveStaff() && request.auth.uid in resource.data.employeeIds)
        || (isActiveStaff() && resource.data.get('targetAll', false) == true && isTech());
      allow create: if creatingManaged() || creatingSelfOnly();
      allow update: if validScheduleBlock(request.resource.data)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && (canManageSchedule()
        || (isActiveStaff()
          && resource.data.createdBy == request.auth.uid
          && request.auth.uid in resource.data.employeeIds
          && request.resource.data.targetAll == false
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['title', 'type', 'color', 'startAt', 'endAt', 'allDay', 'notes', 'updatedAt'])));
      allow delete: if canManageSchedule()
        || (isActiveStaff()
          && resource.data.createdBy == request.auth.uid
          && request.auth.uid in resource.data.employeeIds);
    }
  }
}
